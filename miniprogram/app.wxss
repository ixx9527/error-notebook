/* ========== CSS Variables — Light Mode ========== */
page {
  --color-primary: #6C5CE7;
  --color-primary-light: #A29BFE;
  --color-primary-bg: #EEEAFF;
  --color-primary-dark: #5A4BD1;

  --bg-page: #F6F6FF;
  --bg-card: #FFFFFF;
  --bg-input: #F0F0FA;
  --bg-secondary: #F0F0FA;

  --text-primary: #2D3436;
  --text-secondary: #636E72;
  --text-tertiary: #B2BEC3;
  --text-hint: #CCC;

  --color-success: #00B894;
  --color-error: #FF6B6B;
  --color-warning: #FDCB6E;

  --border-color: #E8E8F0;
  --shadow-color: rgba(108, 92, 231, 0.06);

  --subject-math: #6C5CE7;
  --subject-chinese: #00B894;
  --subject-english: #FDCB6E;
  --subject-other: #B2BEC3;

  background-color: var(--bg-page);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

/* ========== CSS Variables — Dark Mode ========== */
@media (prefers-color-scheme: dark) {
  page {
    --color-primary: #A29BFE;
    --color-primary-light: #6C5CE7;
    --color-primary-bg: #2A2640;
    --color-primary-dark: #C8C3FF;

    --bg-page: #121220;
    --bg-card: #1E1E2E;
    --bg-input: #2A2A3C;
    --bg-secondary: #2A2A3C;

    --text-primary: #E8E8F0;
    --text-secondary: #A0A0B8;
    --text-tertiary: #5A5A72;
    --text-hint: #44445A;

    --color-success: #55EFC4;
    --color-error: #FF7675;
    --color-warning: #FFEAA7;

    --border-color: #2A2A3C;
    --shadow-color: rgba(0, 0, 0, 0.3);

    --subject-math: #A29BFE;
    --subject-chinese: #55EFC4;
    --subject-english: #FFEAA7;
    --subject-other: #5A5A72;
  }
}

/* ========== Global Components ========== */
.container {
  padding: 24rpx;
}

.card {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx var(--shadow-color);
}

.btn-primary {
  background: var(--color-primary);
  color: #fff;
  border-radius: 12rpx;
  padding: 20rpx 0;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-primary:active {
  opacity: 0.85;
}

/* 独立行动按钮 — 胶囊样式 */
.btn-action {
  width: 400rpx;
  margin: 0 auto;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--bg-card);
  border-radius: 48rpx;
}

.btn-secondary {
  background: var(--bg-secondary);
  color: var(--text-secondary);
  border-radius: 12rpx;
  padding: 20rpx 0;
  text-align: center;
  font-size: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.empty-tip {
  text-align: center;
  color: var(--text-tertiary);
  padding: 80rpx 0;
  font-size: 28rpx;
}

.tag {
  display: inline-block;
  background: var(--color-primary-bg);
  color: var(--color-primary);
  border-radius: 8rpx;
  padding: 4rpx 16rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.subject-badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #fff;
}

.subject-math { background: var(--subject-math); }
.subject-chinese { background: var(--subject-chinese); }
.subject-english { background: var(--subject-english); }
.subject-other { background: var(--subject-other); }

.divider {
  height: 1rpx;
  background: var(--border-color);
  margin: 20rpx 0;
}

/* ========== Icon Image ========== */
.icon-img {
  display: inline-block;
  width: 48rpx;
  height: 48rpx;
  -webkit-mask-size: contain;
  mask-size: contain;
  -webkit-mask-repeat: no-repeat;
  mask-repeat: no-repeat;
  -webkit-mask-position: center;
  mask-position: center;
}

.icon-lg {
  width: 80rpx;
  height: 80rpx;
}

.icon-md {
  width: 48rpx;
  height: 48rpx;
}

.icon-sm {
  width: 32rpx;
  height: 32rpx;
}

.icon-primary {
  background-color: var(--color-primary);
}

.icon-muted {
  background-color: var(--text-tertiary);
}
