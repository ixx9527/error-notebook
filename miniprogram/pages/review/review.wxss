.progress-bar {
  height: 8rpx;
  background: var(--bg-secondary);
  border-radius: 4rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: 4rpx;
  transition: width 0.3s;
}

.progress-text {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 20rpx;
}

.review-card {
  min-height: 400rpx;
}

.review-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.review-round {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.review-topic {
  font-size: 26rpx;
  color: var(--color-primary);
  margin-bottom: 16rpx;
}

.review-question {
  font-size: 30rpx;
  line-height: 1.8;
  color: var(--text-primary);
}

.answer-section {
  margin-top: 16rpx;
}

.answer-row {
  display: flex;
  gap: 40rpx;
}

.answer-item {
  flex: 1;
}

.answer-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  display: block;
  margin-bottom: 8rpx;
}

.answer-value {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-error);
}

.answer-value.correct {
  color: var(--color-success);
}

.review-actions {
  margin-top: 30rpx;
}

.rating-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.rating-title {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.rating-stars {
  display: flex;
  gap: 16rpx;
}

.star {
  font-size: 36rpx;
  padding: 12rpx 16rpx;
  background: var(--bg-input);
  border-radius: 12rpx;
}

.star:active {
  background: var(--color-warning);
}

.rating-hint {
  font-size: 22rpx;
  color: var(--text-hint);
}

.complete-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.complete-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.complete-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.complete-desc {
  font-size: 28rpx;
  color: var(--text-tertiary);
}
