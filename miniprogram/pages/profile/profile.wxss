.user-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.avatar-area {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: var(--bg-card);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.user-grade {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.edit-btn {
  font-size: 26rpx;
  color: var(--color-primary);
  padding: 12rpx 20rpx;
}

.field-group {
  margin-bottom: 24rpx;
}

.field-label {
  font-size: 26rpx;
  color: var(--text-tertiary);
  margin-bottom: 12rpx;
  display: block;
  line-height: 1.6;
}

.field-input {
  width: 100%;
  min-height: 80rpx;
  padding: 20rpx;
  background: var(--bg-input);
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.btn-group {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.btn-group .btn-secondary,
.btn-group .btn-primary {
  flex: 1;
}

.menu-card {
  padding: 0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.menu-arrow {
  font-size: 32rpx;
  color: var(--text-hint);
}

.logout-btn {
  text-align: center;
  padding: 28rpx;
  margin-top: 40rpx;
  font-size: 28rpx;
  color: var(--color-error);
  background: var(--bg-card);
  border-radius: 12rpx;
}

/* 孩子管理 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.add-btn {
  font-size: 26rpx;
  color: var(--color-primary);
  padding: 8rpx 16rpx;
}

.child-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.child-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.child-item:last-child {
  border-bottom: none;
}

.child-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.child-name {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.child-grade {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.child-actions {
  display: flex;
  gap: 20rpx;
}

.child-action {
  font-size: 24rpx;
  color: var(--color-primary);
}

.child-action.delete {
  color: var(--color-error);
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-content {
  width: 80%;
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 32rpx;
}

/* 游客视图 */
.guest-profile {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.guest-avatar {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.guest-welcome {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.guest-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
  text-align: center;
  margin-bottom: 48rpx;
  line-height: 1.6;
}

.guest-login-btn {
  width: 360rpx;
  text-align: center;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 600;
}

/* Custom TabBar 底部安全距离 */
.container {
  padding-bottom: 140rpx;
}
