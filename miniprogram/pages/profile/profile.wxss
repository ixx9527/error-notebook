.user-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.avatar-area {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #4A90D9;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.user-grade {
  font-size: 24rpx;
  color: #999;
}

.edit-btn {
  font-size: 26rpx;
  color: #4A90D9;
  padding: 12rpx 20rpx;
}

.field-group {
  margin-bottom: 24rpx;
}

.field-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
  display: block;
}

.field-input {
  width: 100%;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.btn-group {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.btn-group .btn-secondary,
.btn-group .btn-primary {
  flex: 1;
}

.menu-card {
  padding: 0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.logout-btn {
  text-align: center;
  padding: 28rpx;
  margin-top: 40rpx;
  font-size: 28rpx;
  color: #e74c3c;
  background: #fff;
  border-radius: 12rpx;
}

/* 孩子管理 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.add-btn {
  font-size: 26rpx;
  color: #4A90D9;
  padding: 8rpx 16rpx;
}

.child-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.child-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.child-item:last-child {
  border-bottom: none;
}

.child-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.child-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.child-grade {
  font-size: 22rpx;
  color: #999;
}

.child-actions {
  display: flex;
  gap: 20rpx;
}

.child-action {
  font-size: 24rpx;
  color: #4A90D9;
}

.child-action.delete {
  color: #e74c3c;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-content {
  width: 80%;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}
