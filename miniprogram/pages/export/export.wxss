.tab-bar {
  display: flex;
  background: var(--bg-card);
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.tab-item.active {
  color: var(--color-primary);
  font-weight: 600;
  border-bottom: 4rpx solid var(--color-primary);
}

.field-group {
  margin-bottom: 24rpx;
}

.field-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 8rpx;
  display: block;
}

.picker-value {
  padding: 20rpx;
  background: var(--bg-input);
  border-radius: 8rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}
