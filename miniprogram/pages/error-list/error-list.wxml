<view class="container">
  <!-- 筛选栏 -->
  <view class="filter-bar">
    <picker mode="selector" range="{{subjects}}" value="{{subjectIndex}}" bindchange="onSubjectFilter">
      <view class="filter-btn">
        {{subject || '全部科目'}} ▾
      </view>
    </picker>
    <text class="total-count">共 {{total}} 题</text>
  </view>

  <!-- 错题列表 -->
  <view class="error-item card" wx:for="{{items}}" wx:key="id"
    bindtap="goDetail" data-id="{{item.id}}">
    <view class="error-header">
      <text class="subject-badge {{item.subjectClass}}">{{item.subject}}</text>
      <text class="error-time">{{item.timeAgo}}</text>
    </view>
    <view class="error-topic">{{item.topic || '未分类'}}</view>
    <view class="error-question">{{item.question_text}}</view>
    <view class="error-footer">
      <view class="error-tags">
        <text class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
      </view>
      <view class="error-delete" catchtap="deleteItem" data-id="{{item.id}}" data-idx="{{index}}">
        删除
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-tip" wx:if="{{!loading && items.length === 0}}">
    暂无错题，去拍一张吧
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
  <view class="load-more" wx:if="{{noMore && items.length > 0}}">
    <text>没有更多了</text>
  </view>
</view>
