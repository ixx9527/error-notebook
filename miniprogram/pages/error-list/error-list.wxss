.filter-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 16rpx 24rpx;
  background: #fff;
  border-radius: 12rpx;
}

.filter-btn {
  font-size: 26rpx;
  color: #4A90D9;
  padding: 8rpx 20rpx;
  background: #EEF3FA;
  border-radius: 8rpx;
}

.total-count {
  font-size: 24rpx;
  color: #999;
}

.error-item {
  position: relative;
}

.error-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.error-time {
  font-size: 22rpx;
  color: #bbb;
}

.error-topic {
  font-size: 26rpx;
  color: #4A90D9;
  margin-bottom: 8rpx;
}

.error-question {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.error-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.error-tags {
  flex: 1;
  overflow: hidden;
}

.error-delete {
  font-size: 24rpx;
  color: #e74c3c;
  padding: 8rpx 16rpx;
}

.load-more {
  text-align: center;
  padding: 30rpx;
  font-size: 24rpx;
  color: #ccc;
}
