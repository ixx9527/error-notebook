.stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.stat-box {
  flex: 1;
  min-width: 40%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: var(--bg-input);
  border-radius: 12rpx;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
}

/* 趋势图 */
.trend-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.trend-switch {
  display: flex;
  gap: 12rpx;
}

.trend-btn {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  color: var(--text-tertiary);
  background: var(--bg-secondary);
}

.trend-btn.active {
  color: var(--bg-card);
  background: var(--color-primary);
}

.trend-chart {
  display: flex;
  align-items: flex-end;
  height: 200rpx;
  gap: 4rpx;
  padding-top: 20rpx;
}

.trend-bar-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
  justify-content: flex-end;
}

.trend-bar {
  width: 100%;
  min-height: 4rpx;
  background: linear-gradient(180deg, var(--color-primary), var(--color-primary-light));
  border-radius: 4rpx 4rpx 0 0;
  transition: height 0.3s;
}

.trend-date {
  font-size: 16rpx;
  color: var(--text-hint);
  margin-top: 6rpx;
  writing-mode: vertical-lr;
  text-orientation: mixed;
  max-height: 60rpx;
  overflow: hidden;
}

/* 掌握度分布 */
.mastery-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.mastery-label {
  width: 140rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.mastery-track {
  flex: 1;
  height: 24rpx;
  background: var(--bg-secondary);
  border-radius: 12rpx;
  margin: 0 16rpx;
  overflow: hidden;
}

.mastery-fill {
  height: 100%;
  border-radius: 12rpx;
  transition: width 0.3s;
}

.mastery-1 { background: var(--color-error); }
.mastery-2 { background: var(--color-warning); }
.mastery-3 { background: #f1c40f; }
.mastery-4 { background: var(--color-success); }
.mastery-5 { background: var(--color-success); }

.mastery-count {
  width: 50rpx;
  text-align: right;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 科目分布 */
.bar-item {
  margin-bottom: 24rpx;
}

.bar-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.bar-name {
  font-size: 26rpx;
  color: var(--text-primary);
}

.bar-percent {
  font-size: 24rpx;
  color: var(--color-primary);
}

.bar-track {
  height: 20rpx;
  background: var(--bg-secondary);
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary), var(--color-primary-light));
  border-radius: 10rpx;
  transition: width 0.3s;
}

.bar-count {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* 错因分布 */
.error-type-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.error-type-item:last-child {
  border-bottom: none;
}

.error-type-name {
  font-size: 28rpx;
  color: var(--text-primary);
}

.error-type-count {
  font-size: 26rpx;
  color: var(--color-error);
}
