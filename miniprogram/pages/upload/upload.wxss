.choose-area {
  padding: 80rpx 0;
}

.choose-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 80rpx 40rpx;
  background: var(--bg-card);
  border-radius: 16rpx;
  border: 2rpx dashed var(--text-hint);
}

.choose-icon {
  font-size: 80rpx;
}

.choose-text {
  font-size: 32rpx;
  color: var(--text-primary);
}

.choose-hint {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.preview-image {
  width: 100%;
  border-radius: 12rpx;
}

.btn-group {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.btn-group .btn-secondary,
.btn-group .btn-primary {
  flex: 1;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.field-group {
  margin-bottom: 20rpx;
}

.field-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 8rpx;
  display: block;
}

.field-input {
  width: 100%;
  padding: 16rpx;
  background: var(--bg-input);
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.field-row {
  display: flex;
  gap: 20rpx;
}

.field-group.half {
  flex: 1;
}

.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  color: #fff;
  font-size: 30rpx;
}

.loading-hint {
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
}
