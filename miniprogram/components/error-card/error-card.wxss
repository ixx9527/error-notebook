.error-card {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx var(--shadow-color);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.card-time {
  font-size: 22rpx;
  color: var(--text-hint);
}

.card-topic {
  font-size: 26rpx;
  color: var(--color-primary);
  margin-bottom: 8rpx;
}

.card-question {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.card-footer {
  display: flex;
  flex-wrap: wrap;
}
