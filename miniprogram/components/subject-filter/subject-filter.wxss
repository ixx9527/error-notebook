.filter-bar {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 0;
}

.filter-item {
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  background: var(--bg-secondary);
}

.filter-item.active {
  background: var(--color-primary);
  color: var(--bg-card);
}
